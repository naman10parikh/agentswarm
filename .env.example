# agentswarm — environment

# agentswarm itself needs NO secrets and NO API keys.
# It orchestrates local Claude Code panes over tmux; there is nothing to authenticate.
#
# The only optional variables below are for the inherited agent-native harness layer
# (.claude/ + .mcp.json), used only if you run this repo's own self-improvement tooling.
# Leave them unset to run the CLI normally.

# Optional — only if you wire up the harness MCP servers (.mcp.json):
# GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Agent file format extension (harness constant; inlined default is ".energy")
AGENT_FORMAT_EXTENSION=.energy
